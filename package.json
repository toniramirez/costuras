{
  "name": "costuras",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:validate": "node scripts/validate-migrations.mjs",
    "db:test": "node scripts/test-database.mjs",
    "db:types": "node scripts/generate-types.mjs",
    "db:check": "node --env-file=.env.local scripts/apply-migrations.mjs --check",
    "db:push": "node --env-file=.env.local scripts/apply-migrations.mjs",
    "test": "npm run db:test && npm run typecheck && npm run lint",
    "db:verify": "node --env-file=.env.local scripts/verify-remote.mjs",
    "auth:harden": "node --env-file=.env.local scripts/harden-auth.mjs",
    "admin:create": "node --env-file=.env.local scripts/create-admin.mjs",
    "smoke": "node --env-file=.env.local scripts/smoke-test.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "demo:seed": "node --env-file=.env.local scripts/seed-demo.mjs",
    "demo:clean": "node --env-file=.env.local scripts/clean-demo.mjs",
    "smoke:pages": "node --env-file=.env.local scripts/smoke-pages.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
